{
  "expo": {
    "name": "Dice Drop",
    "slug": "topside-merge",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "topside-dicedrop",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.topside.dicedrop",
      "buildNumber": "1",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This helps us show you relevant ads.",
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" },
          { "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork" },
          { "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork" },
          { "SKAdNetworkIdentifier": "2u9pt9hc89.skadnetwork" },
          { "SKAdNetworkIdentifier": "yclnxrl5pm.skadnetwork" },
          { "SKAdNetworkIdentifier": "4fzdc2evr5.skadnetwork" },
          { "SKAdNetworkIdentifier": "4pfyvq9l8r.skadnetwork" },
          { "SKAdNetworkIdentifier": "ludvb6z4gh.skadnetwork" }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.topside.dicedrop",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#EDE8DF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1C1008",
          "resizeMode": "contain",
          "ios": {
            "image": "./assets/images/splash-logo.png",
            "imageWidth": 400
          },
          "android": {
            "image": "./assets/images/splash-logo-android.png",
            "imageWidth": 280
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5499315559222720~7457722144",
          "iosAppId": "ca-app-pub-5499315559222720~1669872133"
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba11a1c2-2cf1-43e1-8558-6b0652efbfd0"
      }
    },
    "owner": "johnmanion"
  }
}
